# Dida365 API Credentials
DIDA365_CLIENT_ID=your_client_id
DIDA365_CLIENT_SECRET=your_client_secret
DIDA365_REDIRECT_URI=http://localhost:8080/callback

# Service Configuration
DIDA365_SERVICE_TYPE=dida365  # or ticktick
# DIDA365_BASE_URL=  # Optional custom API base URL

# Token Storage
DIDA365_TOKEN_FILE=.dida365_token.json 